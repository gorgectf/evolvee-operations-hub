# ── Server ────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ── Database ──────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://opshub:opshub_dev_password@localhost:5432/operations_hub
# SSL is auto-detected: off for localhost, on for any remote host (Railway,
# Render, etc.). Override only if needed: set to "true" or "false".
DATABASE_SSL=

# ── Authentication ────────────────────────────────────────────────────────
# Use a long random string before deploying anywhere. The server refuses to start
# if this is missing, shorter than 32 chars, or a placeholder whenever it is a real
# deployment — i.e. NODE_ENV=production, a remote DATABASE_URL, or any integration
# MODE set to "live". Local sandbox runs (localhost DB, sample mode) still allow a
# weak value for convenience. Generate a strong one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=8h

# ── Frontend origin (CORS) ────────────────────────────────────────────────
# Single URL, or a comma-separated list. Trailing slashes are ignored.
# In production set this to your Netlify URL, e.g. https://your-site.netlify.app
CORS_ORIGIN=http://localhost:5173

# ── First-run seeding ─────────────────────────────────────────────────────
# What the server seeds on startup when the database is empty:
#   demo  - full demo dataset (5 role users + manufacturers/products). For local
#           or sandbox use. ("true" is accepted as an alias for demo.)
#   admin - a SINGLE admin user only. Use this for a live/online deployment.
#   false - nothing (default). Seed manually with "npm run db:seed" or
#           "npm run db:seed:admin".
# Seeding only runs against an empty DB, so it can't create duplicates. After the
# first deploy has seeded you can set this to false.
AUTO_SEED=false

# Admin account created by "admin" mode (AUTO_SEED=admin or npm run db:seed:admin).
# ADMIN_PASSWORD is optional: leave it blank and a strong random password is
# generated and printed ONCE to the console/deploy logs. Never ships a known
# default into a live database.
ADMIN_EMAIL=admin@evolveeradiance.com
ADMIN_NAME=Administrator
ADMIN_PASSWORD=

# ── Cron schedule for the Shopify stock check ────────────────────────────
# Default: every hour on the hour. Format: standard cron (min hour dom mon dow)
STOCK_CHECK_CRON=0 * * * *

# ── Data source modes ─────────────────────────────────────────────────────
# Each source can run in "sample" mode (bundled demo data, no credentials
# needed), "live" mode (real API calls), or "off". Switch each one independently
# as credentials arrive.
SHOPIFY_MODE=sample
ZOHO_CRM_MODE=sample

# ── Shopify (live mode) ───────────────────────────────────────────────────
SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
SHOPIFY_ADMIN_TOKEN=shpat_xxx
SHOPIFY_API_VERSION=2025-04

# ── Zoho CRM (live mode) ──────────────────────────────────────────────────
# Data centre: US = .com (default below), EU = .eu. Match both base URLs to the
# account's region or auth fails.
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REFRESH_TOKEN=
ZOHO_ACCOUNTS_BASE=https://accounts.zoho.com
ZOHO_API_BASE=https://www.zohoapis.com

# The QR partner dashboard is currently a placeholder. Put the relevant variables underneath when ready.
