# ── Server ────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ── Database ──────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://opshub:opshub_dev_password@localhost:5432/operations_hub

# ── Authentication ────────────────────────────────────────────────────────
# Change this to a long random string before deploying anywhere.
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=8h

# ── Frontend origin (CORS) ────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:5173

# ── Cron schedule for the Zoho Inventory stock check ─────────────────────
# Default: every hour on the hour. Format: standard cron (min hour dom mon dow)
STOCK_CHECK_CRON=0 * * * *

# ── Data source modes ─────────────────────────────────────────────────────
SHOPIFY_MODE=sample
ZOHO_INVENTORY_MODE=sample
ZOHO_BOOKS_MODE=sample
ZOHO_CRM_MODE=sample
AFTERSHIP_MODE=sample
QR_PARTNER_MODE=placeholder

# ── Shopify (live mode) ───────────────────────────────────────────────────
SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
SHOPIFY_ADMIN_TOKEN=shpat_xxx
SHOPIFY_API_VERSION=2025-04

# ── Zoho (live mode, shared OAuth app) ────────────────────────────────────
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REFRESH_TOKEN=
ZOHO_ORG_ID=
ZOHO_ACCOUNTS_BASE=https://accounts.zoho.com
ZOHO_API_BASE=https://www.zohoapis.com

# ── AfterShip (live mode) ─────────────────────────────────────────────────
AFTERSHIP_API_KEY=