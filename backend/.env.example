# ── Server ────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ── Database ──────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://opshub:opshub_dev_password@localhost:5432/operations_hub
# SSL is auto-detected: off for localhost, on for any remote host (Railway,
# Render, etc.). Override only if needed: set to "true" or "false".
DATABASE_SSL=

# ── Authentication ────────────────────────────────────────────────────────
# Use a long random string before deploying anywhere. In production the server
# refuses to start if this is missing, shorter than 32 chars, or a placeholder.
# Generate one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=8h

# ── Frontend origin (CORS) ────────────────────────────────────────────────
# Single URL, or a comma-separated list. Trailing slashes are ignored.
# In production set this to your Netlify URL, e.g. https://your-site.netlify.app
CORS_ORIGIN=http://localhost:5173

# ── First-run seeding ─────────────────────────────────────────────────────
# If true, the server seeds demo data on startup when the database is empty.
# Handy for a first cloud deploy (set true once, then back to false). Leave
# false locally and run "npm run db:seed" instead.
AUTO_SEED=false

# ── Cron schedule for the Zoho Inventory stock check ─────────────────────
# Default: every hour on the hour. Format: standard cron (min hour dom mon dow)
STOCK_CHECK_CRON=0 * * * *

# ── Data source modes ─────────────────────────────────────────────────────
# Each source can run in "sample" mode (bundled demo data, no credentials
# needed) or "live" mode (real API calls). Switch each one independently
# as credentials arrive. QR partner module supports "placeholder" or "live".
SHOPIFY_MODE=sample
ZOHO_INVENTORY_MODE=sample
ZOHO_BOOKS_MODE=sample
ZOHO_CRM_MODE=sample
AFTERSHIP_MODE=sample
QR_PARTNER_MODE=placeholder

# ── Shopify (live mode) ───────────────────────────────────────────────────
SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
SHOPIFY_ADMIN_TOKEN=shpat_xxx
SHOPIFY_API_VERSION=2025-04

# ── Zoho (live mode, shared OAuth app) ────────────────────────────────────
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REFRESH_TOKEN=
ZOHO_ORG_ID=
ZOHO_ACCOUNTS_BASE=https://accounts.zoho.com
ZOHO_API_BASE=https://www.zohoapis.com

# ── AfterShip (live mode) ─────────────────────────────────────────────────
AFTERSHIP_API_KEY=

# ── QR Partner Dashboard (live mode, once access confirmed) ──────────────
QR_PARTNER_API_BASE=
QR_PARTNER_API_KEY=
